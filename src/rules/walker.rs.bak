#[test]
fn explore_ast() {
    let source = r#"
function f(x: number, y = 5, z: boolean = false) {}
const isReady: boolean = true;
let hasValue = false;
const ok = (a: boolean) => a;
export { foo };
const first = 1;
export const second = 2;
"#;
    let mut parser = tree_sitter::Parser::new();
    parser.set_language(&tree_sitter_typescript::LANGUAGE_TYPESCRIPT.into()).unwrap();
    let tree = parser.parse(source, None).unwrap();
    walk(tree.root_node(), source, 0);
}

fn walk(node: tree_sitter::Node, source: &str, depth: usize) {
    if depth > 8 { return; }
    let text = source[node.byte_range()].lines().next().unwrap_or("").chars().take(50).collect::<String>();
    println!("{:indent$}{} [{}]", "", node.kind(), text, indent = depth * 2);
    let mut cursor = node.walk();
    if cursor.goto_first_child() {
        loop {
            walk(cursor.node(), source, depth + 1);
            if !cursor.goto_next_sibling() { break; }
        }
    }
}
